# ============================================================
# KMRL NexusAI — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Application ───────────────────────────────────────────────────────────
APP_NAME="KMRL NexusAI"
APP_VERSION="2.4.1"
ENVIRONMENT="development"          # development | staging | production
DEBUG="true"
ALLOWED_HOSTS="*"                  # comma-separated in production

# ── Security ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY="CHANGE_ME_USE_OPENSSL_RAND_HEX_32_MINIMUM"

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://kmrl:kmrl_secret@localhost:5432/kmrl_nexusai"
DATABASE_POOL_SIZE="20"
DATABASE_MAX_OVERFLOW="10"
DATABASE_ECHO="false"

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_TTL="300"

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="60"
JWT_REFRESH_TOKEN_EXPIRE_DAYS="7"

# ── Keycloak SSO (optional — falls back to local JWT) ─────────────────────
KEYCLOAK_SERVER_URL="http://keycloak:8080"
KEYCLOAK_REALM="kmrl"
KEYCLOAK_CLIENT_ID="kmrl-nexusai"
KEYCLOAK_CLIENT_SECRET="CHANGE_ME"

# ── HashiCorp Vault (optional — falls back to env vars) ───────────────────
VAULT_ADDR="http://vault:8200"
VAULT_NAMESPACE="kmrl"
VAULT_K8S_ROLE="kmrl-api"
VAULT_TOKEN=""                     # for dev only; K8s SA used in production

# ── Kafka ─────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_TOPIC_TELEMETRY="kmrl.trainset.telemetry"
KAFKA_TOPIC_ALERTS="kmrl.alerts"
KAFKA_TOPIC_INDUCTION="kmrl.induction.plans"
KAFKA_CONSUMER_GROUP="kmrl-nexusai"

# ── Celery ────────────────────────────────────────────────────────────────
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# ── ML ────────────────────────────────────────────────────────────────────
ML_MODEL_PATH="/app/models"
ML_RETRAIN_SCHEDULE="0 3 * * *"
ML_MIN_TRAINING_SAMPLES="500"
FEATURE_STORE_PATH="/app/feature_store"

# ── Optimization ─────────────────────────────────────────────────────────
OPTIMIZER_TIMEOUT_SECONDS="30"
OPTIMIZER_MAX_ITERATIONS="10000"
FLEET_SIZE="25"
FLEET_SIZE_TARGET="40"
PLANNING_WINDOW_START_HOUR="21"
PLANNING_WINDOW_END_HOUR="23"

# ── Alerts ────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="nexusai@kmrl.in"
SMTP_PASSWORD="CHANGE_ME"
ALERT_EMAIL_FROM="nexusai@kmrl.in"

# WhatsApp Business API (360dialog / Twilio)
WHATSAPP_API_URL="https://waba.360dialog.io/v1/messages"
WHATSAPP_API_TOKEN="CHANGE_ME"

# ── Observability ─────────────────────────────────────────────────────────
OTLP_ENDPOINT="http://jaeger:4317"
SENTRY_DSN=""                      # optional error tracking
PROMETHEUS_ENABLED="true"
LOG_LEVEL="INFO"

# ── Storage ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="kmrl_admin"
MINIO_SECRET_KEY="CHANGE_ME"
MINIO_BUCKET_MODELS="kmrl-ml-models"
MINIO_BUCKET_REPORTS="kmrl-reports"

# AWS S3 (alternative to MinIO in production)
AWS_REGION="ap-south-1"
AWS_S3_BUCKET_MODELS="kmrl-nexusai-models"
AWS_S3_BUCKET_REPORTS="kmrl-nexusai-reports"

# ── Multi-Region ──────────────────────────────────────────────────────────
REGION="india-south"               # india-south | india-west
ROLE="primary"                     # primary | replica
PEER_REGION="india-west"
SYNC_ENABLED="false"               # enable in production multi-region

# ── Frontend (Next.js) ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:8000"
NEXT_PUBLIC_WS_URL="ws://localhost:8000"
NEXT_PUBLIC_APP_VERSION="2.4.1"
NEXT_PUBLIC_APP_NAME="KMRL NexusAI"

# ── IBM Maximo Integration ────────────────────────────────────────────────
MAXIMO_BASE_URL="https://maximo.kmrl.in/maximo/oslc"
MAXIMO_API_KEY="CHANGE_ME"
MAXIMO_WORK_ORDER_RESOURCE="mxwo"
MAXIMO_ASSET_RESOURCE="mxasset"

# ── Third-party Monitoring ────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD="CHANGE_ME"
GRAFANA_ROOT_URL="https://grafana.nexusai.kmrl.in"
JAEGER_AGENT_HOST="jaeger"
JAEGER_AGENT_PORT="6831"
